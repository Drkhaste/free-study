{
  "name": "medical-edu-cloudflare",
  "version": "1.0.0",
  "description": "Medical education platform on Cloudflare Workers with D1, Gemini AI, Telegram bot, flashcards (SM-2) and blog",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create medical-edu-db",
    "db:migrate": "wrangler d1 execute medical-edu-db --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute medical-edu-db --remote --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.10",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "marked": "^14.1.3",
    "dompurify": "^3.1.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.78.12",
    "@types/bcryptjs": "^2.4.6"
  }
}
